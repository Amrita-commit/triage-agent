# Copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

# Anthropic Claude API key (required from Phase 2 onward for the agents).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model routing (see copilot-core ModelRouter). Cheap steps -> Haiku, planning -> Sonnet.
COPILOT_MODEL_CHEAP=claude-haiku-4-5-20251001
COPILOT_MODEL_PLANNING=claude-sonnet-5

# Local telemetry endpoints (defaults match docker-compose service names).
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# Demo app base URL (used by the eval harness to inject faults).
DEMO_APP_URL=http://demo-app:8080
